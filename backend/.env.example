# Database Configuration
DATABASE_URL=mssql+pyodbc://user:password@localhost\SQLEXPRESS02/inventory_ai?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# JWT Settings
JWT_SECRET_KEY=your-long-random-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=

# Ollama AI Settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_PRIMARY=gpt-oss:latest
OLLAMA_MODEL_FALLBACKS=gemma4:latest,qwen3.6:latest

# ComfyUI Image Generation
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=./workflows/product_image_workflow_api.json
COMFYUI_TIMEOUT_SECONDS=180

# OpenRouteService (optional, for maps)
OPENROUTESERVICE_API_KEY=

# Feature Flags
SEED_DEFAULT_USERS=True
